"""
Auto-generated script: CUSIP month-over-month attribution analysis.
Generated by MBS Prepayment Attribution Agent — do not edit manually.

Analysis type : cusip_attribution
Baseline      : {{ plan.ig_params.baseline_strategy }}
n_steps       : {{ plan.ig_params.n_steps }}
Target output : {{ plan.ig_params.target_output }}
"""

import json
import pathlib
import numpy as np
import pandas as pd
import torch
import joblib
from captum.attr import IntegratedGradients

# ---------------------------------------------------------------------------
# Configuration (injected by template renderer)
# ---------------------------------------------------------------------------
CUSIP_LIST        = {{ plan.data_spec.cusip_list | tojson }}
COMPARISON_MONTHS = {{ plan.comparison_months | tojson }}   # ordered list e.g. ["2024-01","2024-02"]
MODEL_CHECKPOINT  = "{{ plan.model_spec.checkpoint_path }}"
FEATURE_NAMES     = {{ plan.model_spec.feature_names | tojson }}
SCALER_PATH       = "{{ mbs_settings.scaler_path }}"
BASELINE_STRATEGY = "{{ plan.ig_params.baseline_strategy }}"  # "zero" | "mean"
N_STEPS           = {{ plan.ig_params.n_steps }}
TARGET_OUTPUT     = "{{ plan.ig_params.target_output }}"
OUTPUT_INDEX      = 0 if TARGET_OUTPUT == "cpr" else 1
BATCH_SIZE        = {{ plan.ig_params.batch_size }}

# Single parquet file containing all data
DATA_FILE         = pathlib.Path("{{ mbs_settings.data_file }}")
CUSIP_COL         = "{{ mbs_settings.cusip_col }}"    # e.g. "cusip"
DATE_COL          = "{{ mbs_settings.date_col }}"     # e.g. "fh_effdt"
DATE_FORMAT       = "{{ mbs_settings.date_format }}"  # e.g. "%Y%m%d" for integer 20240301
OUTPUT_DIR        = pathlib.Path("{{ output_dir }}")

# ---------------------------------------------------------------------------
# Load model and scaler
# ---------------------------------------------------------------------------
model = torch.load(MODEL_CHECKPOINT, map_location="cpu", weights_only=False)
model.eval()

scaler = joblib.load(SCALER_PATH)
# scaler.mean_  : shape [n_features] — per-feature means from training data
# scaler.scale_ : shape [n_features] — per-feature stds  from training data
feature_means  = np.array(scaler.mean_,  dtype=np.float64)
feature_scales = np.array(scaler.scale_, dtype=np.float64)

ig = IntegratedGradients(model)

# ---------------------------------------------------------------------------
# Load dataset once and index for fast filtering
# ---------------------------------------------------------------------------
print(f"Loading data from {DATA_FILE} ...", flush=True)
df_all = pd.read_parquet(DATA_FILE)

# Normalise the date column to "YYYY-MM" period strings for easy month matching.
# astype(str) handles integer dates like 20240301 before parsing with the configured format.
df_all["_month"] = (
    pd.to_datetime(df_all[DATE_COL].astype(str), format=DATE_FORMAT, errors="coerce")
    .dt.to_period("M")
    .astype(str)
)

# Validate required columns
missing_feats = [f for f in FEATURE_NAMES if f not in df_all.columns]
if missing_feats:
    raise ValueError(f"Feature columns missing from data file: {missing_feats}")
if CUSIP_COL not in df_all.columns:
    raise ValueError(f"CUSIP column '{CUSIP_COL}' not found in data file.")

# ---------------------------------------------------------------------------
# Data loading helper — filters from the single parquet
# ---------------------------------------------------------------------------
def load_cusip_month(cusip: str, month: str) -> torch.Tensor:
    """
    Return a float32 tensor [n_rows, n_features] of normalized features for
    (cusip, month). Raises ValueError if no rows match.
    Data on disk is already normalized (mean=0, std=1) as fed to the model.
    """
    mask = (df_all[CUSIP_COL] == cusip) & (df_all["_month"] == month)
    rows = df_all.loc[mask, FEATURE_NAMES]
    if rows.empty:
        raise ValueError(
            f"No data for CUSIP={cusip}, month={month} in {DATA_FILE}. "
            f"Available months for this CUSIP: "
            f"{sorted(df_all.loc[df_all[CUSIP_COL]==cusip, '_month'].unique().tolist())}"
        )
    return torch.tensor(rows.values.astype(np.float32), dtype=torch.float32)

# ---------------------------------------------------------------------------
# Attribution computation
# ---------------------------------------------------------------------------
attributions_normalized = {}
attributions_original   = {}
feature_values_original = {}

months = COMPARISON_MONTHS or []
if len(months) < 2:
    raise ValueError("comparison_months must contain at least 2 months for attribution.")

for cusip in CUSIP_LIST:
    attributions_normalized[cusip] = {}
    attributions_original[cusip]   = {}
    feature_values_original[cusip] = {}

    for i in range(len(months) - 1):
        month_t0, month_t1 = months[i], months[i + 1]
        period_key = f"{month_t0}->{month_t1}"

        try:
            x_t0 = load_cusip_month(cusip, month_t0)  # [n_rows, n_features] normalized
            x_t1 = load_cusip_month(cusip, month_t1)  # [n_rows, n_features] normalized
        except ValueError as e:
            attributions_normalized[cusip][period_key] = {"error": str(e)}
            attributions_original[cusip][period_key]   = {"error": str(e)}
            feature_values_original[cusip][period_key] = {"error": str(e)}
            continue

        # Baseline selection
        if BASELINE_STRATEGY == "zero":
            baseline = torch.zeros_like(x_t1)
        else:
            # "mean" strategy: use previous month as baseline
            # Align row counts (use min length)
            n = min(x_t0.shape[0], x_t1.shape[0])
            baseline = x_t0[:n]
            x_t1 = x_t1[:n]

        # Run Integrated Gradients in batches to avoid OOM
        all_attr_norm = []
        for start in range(0, x_t1.shape[0], BATCH_SIZE):
            batch      = x_t1[start : start + BATCH_SIZE]
            batch_base = baseline[start : start + BATCH_SIZE]
            attr, _delta = ig.attribute(
                batch,
                baselines=batch_base,
                target=OUTPUT_INDEX,
                n_steps=N_STEPS,
                return_convergence_delta=True,
            )
            all_attr_norm.append(attr.detach().numpy())

        # Mean attribution across all samples: shape [n_features]
        attr_norm_np = np.concatenate(all_attr_norm, axis=0).mean(axis=0)

        # Rescale to original feature units using chain rule:
        #   x_norm = (x - mean) / scale  =>  dx_norm/dx = 1/scale
        #   IG gives d_output/d_x_norm, so d_output/d_x_orig = attr_norm / scale
        attr_orig_np = attr_norm_np / feature_scales

        # Inverse-transform t1 feature values to original scale for report context
        x_t1_orig = scaler.inverse_transform(x_t1.numpy())  # [n_rows, n_features]
        x_t1_orig_mean = x_t1_orig.mean(axis=0)             # [n_features]

        attributions_normalized[cusip][period_key] = dict(zip(FEATURE_NAMES, attr_norm_np.tolist()))
        attributions_original[cusip][period_key]   = dict(zip(FEATURE_NAMES, attr_orig_np.tolist()))
        feature_values_original[cusip][period_key] = dict(zip(FEATURE_NAMES, x_t1_orig_mean.tolist()))

# ---------------------------------------------------------------------------
# Summary statistics (across all CUSIPs and periods, in original scale)
# ---------------------------------------------------------------------------
all_attr_orig_by_feature: dict[str, list[float]] = {f: [] for f in FEATURE_NAMES}
for cusip_data in attributions_original.values():
    for period_data in cusip_data.values():
        if "error" not in period_data:
            for feat, val in period_data.items():
                all_attr_orig_by_feature[feat].append(val)

summary_stats = {
    feat: {
        "mean_attr_original": float(np.mean(vals)) if vals else 0.0,
        "std_attr_original":  float(np.std(vals))  if vals else 0.0,
    }
    for feat, vals in all_attr_orig_by_feature.items()
}

# ---------------------------------------------------------------------------
# Write standardized output.json
# ---------------------------------------------------------------------------
OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
result = {
    "analysis_type": "cusip_attribution",
    "attributions_normalized": attributions_normalized,
    "attributions_original":   attributions_original,
    "feature_values_original": feature_values_original,
    "metadata": {
        "n_steps":          N_STEPS,
        "baseline":         BASELINE_STRATEGY,
        "target_output":    TARGET_OUTPUT,
        "cusip_count":      len(CUSIP_LIST),
        "period_count":     len(months) - 1,
        "feature_count":    len(FEATURE_NAMES),
        "data_file":        str(DATA_FILE),
    },
    "summary_stats": summary_stats,
}
(OUTPUT_DIR / "output.json").write_text(json.dumps(result, indent=2), encoding="utf-8")
print(f"Attribution analysis complete. Results written to {OUTPUT_DIR / 'output.json'}")
