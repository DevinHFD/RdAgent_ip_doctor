def load_scenario_features(cusip: str, scenario: str) -> np.ndarray:
    """Load normalized features for a CUSIP+scenario, averaged across dates if multi-row."""
    fname = f"{cusip}_{scenario}.parquet"
    fpath = Path(DATA_DIR) / fname
    if not fpath.exists():
        raise FileNotFoundError(
            f"Expected scenario data file not found: {fpath}\n"
            f"  CUSIP={cusip}, scenario={scenario}"
        )
    df = pd.read_parquet(fpath)
    # Use only the configured feature columns
    missing = [f for f in FEATURE_NAMES if f not in df.columns]
    if missing:
        raise ValueError(f"Missing features {missing} in {fpath}")
    arr = df[FEATURE_NAMES].values.astype(np.float32)
    return arr  # shape: [n_dates, n_features]


# ---------------------------------------------------------------------------
# Integrated Gradients runner
# ---------------------------------------------------------------------------

ig = IntegratedGradients(model)


def run_ig_batched(scenario_arr: np.ndarray, baseline_arr: np.ndarray) -> np.ndarray:
    """
    Run IG in batches.
    scenario_arr : [n_dates, n_features]  normalized
    baseline_arr : [n_dates, n_features]  normalized
    Returns attr_norm_mean : [n_features] averaged over all dates
    """
    all_attrs = []
    n = scenario_arr.shape[0]
    for start in range(0, n, BATCH_SIZE):
        end = min(start + BATCH_SIZE, n)
        x_batch = torch.tensor(scenario_arr[start:end], dtype=torch.float32)
        b_batch = torch.tensor(baseline_arr[start:end], dtype=torch.float32)
        attr, delta = ig.attribute(
            x_batch,
            baselines=b_batch,
            target=OUTPUT_INDEX,
            n_steps=N_STEPS,
            return_convergence_delta=True,
        )
        all_attrs.append(attr.detach().numpy())
        print(
            f"  Batch {start}-{end}: convergence_delta mean={delta.mean().item():.6f}",
            flush=True,
        )
    return np.concatenate(all_attrs, axis=0).mean(axis=0)  # [n_features]


