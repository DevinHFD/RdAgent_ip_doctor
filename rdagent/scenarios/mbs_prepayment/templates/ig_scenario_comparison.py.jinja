"""
Generated analysis script — Integrated Gradients scenario comparison.
Compares each stress scenario against a base scenario to explain model output differences.

All data is read from a single parquet file. Scenarios are defined by date windows:
  scenario_params = {
      "base":       ["2023-01", "2023-06"],   # [start_month, end_month] inclusive
      "rate_shock": ["2023-07", "2023-12"],
  }
The rows for each scenario are selected by filtering CUSIP + fh_effdt within the window.

Auto-generated by code_generator_node; do not edit manually.
"""

import json
from pathlib import Path

import joblib
import numpy as np
import pandas as pd
import torch
from captum.attr import IntegratedGradients

# ---------------------------------------------------------------------------
# Configuration (injected by Jinja)
# ---------------------------------------------------------------------------

CUSIP_LIST        = {{ plan.data_spec.cusip_list | tojson }}
# scenario_params: {scenario_name: [start_month_YYYY-MM, end_month_YYYY-MM]}
SCENARIO_PARAMS   = {{ plan.data_spec.scenario_params | tojson }}
SCENARIO_NAMES    = {{ (plan.scenario_names or []) | tojson }}

MODEL_CHECKPOINT  = r"{{ plan.model_spec.checkpoint_path }}"
FEATURE_NAMES     = {{ plan.model_spec.feature_names | tojson }}
SCALER_PATH       = r"{{ mbs_settings.scaler_path }}"

BASELINE_STRATEGY = "{{ plan.ig_params.baseline_strategy }}"  # "zero" | "mean"
N_STEPS           = {{ plan.ig_params.n_steps }}
BATCH_SIZE        = {{ plan.ig_params.batch_size }}
TARGET_OUTPUT     = "{{ plan.ig_params.target_output }}"
OUTPUT_INDEX      = 0 if TARGET_OUTPUT == "cpr" else 1

# Single parquet file containing all data
DATA_FILE         = r"{{ mbs_settings.data_file }}"
CUSIP_COL         = "{{ mbs_settings.cusip_col }}"
DATE_COL          = "{{ mbs_settings.date_col }}"
OUTPUT_DIR        = r"{{ output_dir }}"

# ---------------------------------------------------------------------------
# Load model and scaler
# ---------------------------------------------------------------------------

print(f"[ig_scenario_comparison] Loading model from {MODEL_CHECKPOINT}", flush=True)
model = torch.load(MODEL_CHECKPOINT, weights_only=False)
model.eval()

print(f"[ig_scenario_comparison] Loading scaler from {SCALER_PATH}", flush=True)
scaler = joblib.load(SCALER_PATH)
feature_scales = np.array(scaler.scale_, dtype=np.float64)  # shape: [n_features]

# ---------------------------------------------------------------------------
# Load dataset once and index for fast filtering
# ---------------------------------------------------------------------------

print(f"[ig_scenario_comparison] Loading data from {DATA_FILE}", flush=True)
df_all = pd.read_parquet(DATA_FILE)

# Normalise the date column to "YYYY-MM" period strings
df_all["_month"] = pd.to_datetime(df_all[DATE_COL], errors="coerce").dt.to_period("M").astype(str)

missing_feats = [f for f in FEATURE_NAMES if f not in df_all.columns]
if missing_feats:
    raise ValueError(f"Feature columns missing from data file: {missing_feats}")
if CUSIP_COL not in df_all.columns:
    raise ValueError(f"CUSIP column '{CUSIP_COL}' not found in data file.")

# ---------------------------------------------------------------------------
# Data loading helper — filter single parquet by CUSIP + date window
# ---------------------------------------------------------------------------

def load_scenario_features(cusip: str, scenario: str) -> np.ndarray:
    """
    Return float32 array [n_rows, n_features] of normalized features for
    (cusip, scenario). The date window for each scenario is taken from
    SCENARIO_PARAMS[scenario] = [start_month, end_month] (both inclusive, YYYY-MM).
    Raises ValueError if no rows match.
    """
    if scenario not in SCENARIO_PARAMS:
        raise ValueError(
            f"Scenario '{scenario}' not found in scenario_params. "
            f"Available: {list(SCENARIO_PARAMS.keys())}"
        )
    date_range = SCENARIO_PARAMS[scenario]
    start_month, end_month = date_range[0], date_range[1]

    mask = (
        (df_all[CUSIP_COL] == cusip)
        & (df_all["_month"] >= start_month)
        & (df_all["_month"] <= end_month)
    )
    rows = df_all.loc[mask, FEATURE_NAMES]
    if rows.empty:
        raise ValueError(
            f"No data for CUSIP={cusip}, scenario={scenario} "
            f"(date window {start_month} to {end_month}) in {DATA_FILE}."
        )
    return rows.values.astype(np.float32)  # [n_rows, n_features]


# ---------------------------------------------------------------------------
# Integrated Gradients runner
# ---------------------------------------------------------------------------

ig = IntegratedGradients(model)


def run_ig_batched(scenario_arr: np.ndarray, baseline_arr: np.ndarray) -> np.ndarray:
    """
    Run IG in batches.
    scenario_arr : [n_rows, n_features]  normalized
    baseline_arr : [n_rows, n_features]  normalized
    Returns attr_norm_mean : [n_features] averaged over all rows
    """
    all_attrs = []
    n = scenario_arr.shape[0]
    for start in range(0, n, BATCH_SIZE):
        end = min(start + BATCH_SIZE, n)
        x_batch = torch.tensor(scenario_arr[start:end], dtype=torch.float32)
        b_batch = torch.tensor(baseline_arr[start:end], dtype=torch.float32)
        attr, delta = ig.attribute(
            x_batch,
            baselines=b_batch,
            target=OUTPUT_INDEX,
            n_steps=N_STEPS,
            return_convergence_delta=True,
        )
        all_attrs.append(attr.detach().numpy())
        print(
            f"  Batch {start}-{end}: convergence_delta mean={delta.mean().item():.6f}",
            flush=True,
        )
    return np.concatenate(all_attrs, axis=0).mean(axis=0)  # [n_features]


# ---------------------------------------------------------------------------
# Main computation
# ---------------------------------------------------------------------------

# Determine which scenarios to compare (everything except "base")
if SCENARIO_NAMES:
    scenarios_to_run = [s for s in SCENARIO_NAMES if s != "base"]
else:
    scenarios_to_run = [s for s in SCENARIO_PARAMS.keys() if s != "base"]

if not scenarios_to_run:
    raise ValueError(
        "No non-base scenario names found. scenario_params must contain at least "
        "one scenario besides 'base', e.g. {'base': [...], 'rate_shock': [...]}."
    )

if "base" not in SCENARIO_PARAMS:
    raise ValueError(
        "scenario_params must include a 'base' entry with its date window, "
        "e.g. {'base': ['2023-01', '2023-06'], 'shock': ['2023-07', '2023-12']}."
    )

attributions_normalized: dict = {}
attributions_original: dict   = {}
feature_values_original: dict = {}

for cusip in CUSIP_LIST:
    print(f"\n[ig_scenario_comparison] Processing CUSIP={cusip}", flush=True)

    # Load base scenario features (normalized)
    try:
        base_arr = load_scenario_features(cusip, "base")
    except ValueError as e:
        print(f"  WARNING: {e}. Skipping CUSIP {cusip}.", flush=True)
        continue

    cusip_attr_norm = {}
    cusip_attr_orig = {}
    cusip_feat_orig = {}

    for scenario in scenarios_to_run:
        print(f"  Scenario: {scenario}", flush=True)
        try:
            scenario_arr = load_scenario_features(cusip, scenario)
        except ValueError as e:
            print(f"  WARNING: {e}. Skipping scenario {scenario} for CUSIP {cusip}.", flush=True)
            continue

        # Align row counts
        n_rows = min(base_arr.shape[0], scenario_arr.shape[0])
        if base_arr.shape[0] != scenario_arr.shape[0]:
            print(
                f"  WARNING: base rows={base_arr.shape[0]}, scenario rows={scenario_arr.shape[0]}. "
                f"Using first {n_rows} rows.",
                flush=True,
            )
        base_slice     = base_arr[:n_rows]
        scenario_slice = scenario_arr[:n_rows]

        # Baseline for IG
        if BASELINE_STRATEGY == "zero":
            baseline_slice = np.zeros_like(scenario_slice)
        else:
            # "mean" — use base scenario rows as IG baseline
            baseline_slice = base_slice

        # Run IG in normalized space
        attr_norm_mean = run_ig_batched(scenario_slice, baseline_slice)  # [n_features]

        # Rescale attributions to original scale via chain rule:
        #   x_norm = (x_orig - mean) / scale
        #   d_output/d_x_orig = (d_output/d_x_norm) * (1/scale)
        attr_orig_mean = attr_norm_mean / feature_scales

        # Original-scale feature values for context
        x_orig = scaler.inverse_transform(scenario_slice)  # [n_rows, n_features]
        feat_orig_mean = x_orig.mean(axis=0)               # [n_features]

        cusip_attr_norm[scenario] = {feat: float(v) for feat, v in zip(FEATURE_NAMES, attr_norm_mean)}
        cusip_attr_orig[scenario] = {feat: float(v) for feat, v in zip(FEATURE_NAMES, attr_orig_mean)}
        cusip_feat_orig[scenario] = {feat: float(v) for feat, v in zip(FEATURE_NAMES, feat_orig_mean)}

    if cusip_attr_orig:
        attributions_normalized[cusip] = cusip_attr_norm
        attributions_original[cusip]   = cusip_attr_orig
        feature_values_original[cusip] = cusip_feat_orig

# ---------------------------------------------------------------------------
# Summary stats: aggregate across all CUSIPs and scenarios
# ---------------------------------------------------------------------------

summary_stats: dict = {}
feat_values_agg: dict[str, list] = {f: [] for f in FEATURE_NAMES}
for cusip_data in attributions_original.values():
    for scenario_data in cusip_data.values():
        for feat, val in scenario_data.items():
            if feat in feat_values_agg:
                feat_values_agg[feat].append(val)

for feat, vals in feat_values_agg.items():
    if vals:
        arr = np.array(vals)
        summary_stats[feat] = {
            "mean_attr_original": float(arr.mean()),
            "std_attr_original":  float(arr.std()),
        }

# ---------------------------------------------------------------------------
# Write output.json
# ---------------------------------------------------------------------------

output_path = Path(OUTPUT_DIR) / "output.json"
output_path.parent.mkdir(parents=True, exist_ok=True)

output = {
    "analysis_type": "scenario_comparison",
    "attributions_normalized": attributions_normalized,
    "attributions_original":   attributions_original,
    "feature_values_original": feature_values_original,
    "metadata": {
        "cusip_list":          CUSIP_LIST,
        "scenarios_compared":  scenarios_to_run,
        "scenario_params":     SCENARIO_PARAMS,
        "baseline_strategy":   BASELINE_STRATEGY,
        "n_steps":             N_STEPS,
        "target_output":       TARGET_OUTPUT,
        "feature_names":       FEATURE_NAMES,
        "n_cusips_processed":  len(attributions_original),
        "data_file":           DATA_FILE,
    },
    "summary_stats": summary_stats,
}

with open(output_path, "w") as f:
    json.dump(output, f, indent=2)

print(f"\n[ig_scenario_comparison] Done. Output written to {output_path}", flush=True)
print(f"  CUSIPs processed: {list(attributions_original.keys())}", flush=True)
