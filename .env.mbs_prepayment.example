# =============================================================================
# .env template for the MBS Prepayment scenario (data science loop customization)
# -----------------------------------------------------------------------------
# Copy to `.env` before running the scenario:
#
#     cp .env.mbs_prepayment.example .env
#
# NAMESPACE NOTE:
#   - MBSP_*  → this scenario's own settings (MBSPrepaymentSettings in
#               rdagent/scenarios/mbs_prepayment/conf.py)
#   - MBS_*   → already owned by the ip_doctor LangGraph scenario.
#               Do NOT reuse those keys here; they target a different app.
#   - DS_*    → the RD-Agent data science loop (DataScienceBasePropSetting).
#               Set DS_SCEN to this scenario's class so the loop uses it.
#   - KG_*    → kaggle base settings (inherited by DS). Set KG_LOCAL_DATA_PATH
#               to the folder holding your MBS data + description.md.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Core RD-Agent global + LLM backend (unchanged from base .env.example)
# -----------------------------------------------------------------------------
MAX_RETRY=10
RETRY_WAIT_SECONDS=20

# --- Option A: single API key for chat + embeddings --------------------------
# CHAT_MODEL="gpt-4o"
# EMBEDDING_MODEL="text-embedding-3-small"
# OPENAI_API_BASE="https://your-endpoint.com/v1"
# OPENAI_API_KEY="sk-your-api-key-here"

# --- Option B: separate chat + embedding providers (recommended) -------------
OPENAI_API_KEY="sk-chat-key"
OPENAI_API_BASE="https://xxx-litellm.com/v1"
CHAT_MODEL="gpt-4o"

LITELLM_PROXY_API_KEY="sk-embedding-service-key"
LITELLM_PROXY_API_BASE="https://api.siliconflow.cn/v1"
EMBEDDING_MODEL="litellm_proxy/BAAI/bge-large-en-v1.5"

USE_CHAT_CACHE=True
USE_EMBEDDING_CACHE=True
DS_DOCKER_ENABLE_CACHE=True


# -----------------------------------------------------------------------------
# 2. Data science loop wiring (DS_*, KG_*)
# -----------------------------------------------------------------------------
# Point the data science loop at the MBS scenario class.
DS_SCEN=rdagent.scenarios.mbs_prepayment.scenario.MBSPrepaymentScen

# Competition name — must match the folder name under KG_LOCAL_DATA_PATH
DS_COMPETITION=mbs_prepayment

# Both paths point to the same MBS data root. KG_LOCAL_DATA_PATH is what the
# DS loop uses internally to locate <competition>/description.md.
KG_LOCAL_DATA_PATH=./mbs_data
DS_LOCAL_DATA_PATH=./mbs_data

# Optional DS loop tuning
DS_CODER_MAX_LOOP=10
DS_RUNNER_MAX_LOOP=3
DS_FULL_TIMEOUT=3600
DS_DEBUG_TIMEOUT=600
DS_SAMPLE_DATA_BY_LLM=True
DS_CODER_ON_WHOLE_PIPELINE=True


# -----------------------------------------------------------------------------
# 3. MBS Prepayment — filesystem layout (MBSP_*)
# -----------------------------------------------------------------------------
MBSP_DATA_DIR=./mbs_data
MBSP_MODEL_CHECKPOINT_DIR=./mbs_models
MBSP_OUTPUT_DIR=./mbs_output
MBSP_MEMORY_PATH=./mbs_output/memory.json
MBSP_SEARCH_STATE_PATH=./mbs_output/search_state.json
MBSP_CACHE_DIR=./mbs_output/cache


# -----------------------------------------------------------------------------
# 4. Data contract (scaffold.py, MBSDataContract)
# -----------------------------------------------------------------------------
MBSP_TARGET_COLUMN=smm_decimal
MBSP_TARGET_MIN=0.0
MBSP_TARGET_MAX=1.0
MBSP_CUSIP_COL=cusip
MBSP_DATE_COL=fh_effdt
MBSP_REQUIRED_COLUMNS=rate_incentive,coupon,wala
MBSP_FORBIDDEN_COLUMNS=future_smm,forward_smm,next_month_smm,forward_rate,future_rate_incentive
MBSP_MACRO_LAG_DAYS_MIN=30


# -----------------------------------------------------------------------------
# 5. Temporal train/test split (MBSTrainTestSplit)
# -----------------------------------------------------------------------------
MBSP_TRAIN_END_DATE=2021-12-31
MBSP_EMBARGO_MONTHS=0


# -----------------------------------------------------------------------------
# 6. Evaluation harness (Priority 1, evaluation.py)
# -----------------------------------------------------------------------------
MBSP_COUPON_BUCKETS=0.0:3.0;3.0:3.5;3.5:4.0;4.0:4.5;4.5:5.0;5.0:99.0
MBSP_REGIME_TRANSITION_DATES=2013-05-01,2020-03-01,2022-03-01
MBSP_COUPON_COL=coupon
MBSP_RATE_INCENTIVE_COL=rate_incentive
MBSP_WALA_COL=wala


# -----------------------------------------------------------------------------
# 7. Search strategy (Priority 6, search_strategy.py)
# -----------------------------------------------------------------------------
MBSP_IMPROVEMENT_THRESHOLD=0.05
MBSP_STALL_WINDOW=3
MBSP_COOLDOWN_DURATION=2
MBSP_BACKTRACK_TRIGGER=3


# -----------------------------------------------------------------------------
# 8. Memory / context packing (Priority 7, memory.py)
# -----------------------------------------------------------------------------
MBSP_MEMORY_MAX_FAILURES_SHOWN=3
MBSP_MEMORY_MAX_PROPERTIES_SHOWN=5


# -----------------------------------------------------------------------------
# 9. Domain validator (Priority 8, orchestration.py::DomainValidator)
# -----------------------------------------------------------------------------
MBSP_VALIDATOR_MIN_RATE_SENSITIVITY_CORR=0.3
MBSP_VALIDATOR_MAX_TRAINING_SECONDS=3600.0


# -----------------------------------------------------------------------------
# 10. Phase gates (Priority 8, orchestration.py::PhaseGate)
# -----------------------------------------------------------------------------
MBSP_GATE_BASELINE_MAX_RMSE=0.040
MBSP_GATE_RATE_RESPONSE_MIN_MONOTONICITY=0.7
MBSP_GATE_RATE_RESPONSE_MIN_S_CURVE_R2=0.6
MBSP_GATE_RATE_RESPONSE_INFLECTION_MIN_BPS=50.0
MBSP_GATE_RATE_RESPONSE_INFLECTION_MAX_BPS=150.0
MBSP_GATE_DYNAMICS_MAX_WORST_COUPON_RMSE=0.035
MBSP_GATE_MACRO_REGIME_TRANSITION_RATIO=2.0

MBSP_PHASE_BUDGET_BASELINE=5
MBSP_PHASE_BUDGET_RATE_RESPONSE=8
MBSP_PHASE_BUDGET_DYNAMICS=8
MBSP_PHASE_BUDGET_MACRO_REGIME=6
MBSP_PHASE_BUDGET_ENSEMBLE=4


# -----------------------------------------------------------------------------
# 11. Execution environment per-stage budgets (Priority 9, execution_env.py)
# -----------------------------------------------------------------------------
MBSP_STAGE_DATA_LOAD_TIMEOUT=300
MBSP_STAGE_DATA_LOAD_MEMORY_GB=16.0
MBSP_STAGE_FEATURE_ENG_TIMEOUT=600
MBSP_STAGE_FEATURE_ENG_MEMORY_GB=24.0
MBSP_STAGE_TRAINING_TIMEOUT=3600
MBSP_STAGE_TRAINING_MEMORY_GB=32.0
MBSP_STAGE_TRAINING_ALLOW_GPU=True
MBSP_STAGE_EVALUATION_TIMEOUT=300
MBSP_STAGE_EVALUATION_MEMORY_GB=8.0
MBSP_STAGE_ATTRIBUTION_TIMEOUT=900
MBSP_STAGE_ATTRIBUTION_MEMORY_GB=16.0
MBSP_STAGE_ATTRIBUTION_ALLOW_GPU=True


# -----------------------------------------------------------------------------
# 12. Personas (Priority 10, personas.py)
# -----------------------------------------------------------------------------
MBSP_PERSONA_QUANT_RESEARCHER_MODEL=gpt-4-turbo
MBSP_PERSONA_QUANT_RESEARCHER_TEMPERATURE=0.7
MBSP_PERSONA_ML_ENGINEER_MODEL=gpt-4-turbo
MBSP_PERSONA_ML_ENGINEER_TEMPERATURE=0.2
MBSP_PERSONA_MODEL_VALIDATOR_MODEL=gpt-4-turbo
MBSP_PERSONA_MODEL_VALIDATOR_TEMPERATURE=0.3
MBSP_PERSONA_DATA_ENGINEER_MODEL=gpt-4o-mini
MBSP_PERSONA_DATA_ENGINEER_TEMPERATURE=0.1


# -----------------------------------------------------------------------------
# 13. Interpretability (Priority 4, interpretability.py)
# -----------------------------------------------------------------------------
MBSP_INTERPRETABILITY_N_SAMPLES=500
MBSP_INTERPRETABILITY_BASELINE_STRATEGY=zero
MBSP_IG_N_STEPS=50
MBSP_IG_TARGET_OUTPUT=cpr
MBSP_IG_BATCH_SIZE=32


# -----------------------------------------------------------------------------
# 14. Reproducibility
# -----------------------------------------------------------------------------
MBSP_RANDOM_SEED=42
MBSP_LOG_LEVEL=INFO
