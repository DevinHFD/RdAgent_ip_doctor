# =============================================================================
# .env template for the MBS Prepayment scenario
# -----------------------------------------------------------------------------
# Copy to `.env` (or source into your shell) before running the scenario:
#
#     cp .env.mbs_prepayment.example .env
#
# All MBS-specific variables use the `MBS_` prefix so pydantic_settings can
# pick them up via env_prefix="MBS_". Defaults shown here mirror the dataclass
# defaults in rdagent/scenarios/mbs_prepayment/*.py — change values in-place
# rather than deleting keys so the file remains self-documenting.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Core RD-Agent global + LLM backend
# -----------------------------------------------------------------------------

# Global retry policy for any LLM/HTTP call
MAX_RETRY=10
RETRY_WAIT_SECONDS=20

# Backend class (leave commented to use the default LiteLLM backend)
# BACKEND=rdagent.oai.backend.LiteLLMAPIBackend

# --- Option A: single API key for chat + embeddings --------------------------
# CHAT_MODEL="gpt-4o"
# EMBEDDING_MODEL="text-embedding-3-small"
# OPENAI_API_BASE="https://your-endpoint.com/v1"
# OPENAI_API_KEY="sk-your-api-key-here"

# --- Option B: separate chat + embedding providers (recommended) -------------
OPENAI_API_KEY="sk-chat-key"
OPENAI_API_BASE="https://xxx-litellm.com/v1"
CHAT_MODEL="gpt-4o"

LITELLM_PROXY_API_KEY="sk-embedding-service-key"
LITELLM_PROXY_API_BASE="https://api.siliconflow.cn/v1"
EMBEDDING_MODEL="litellm_proxy/BAAI/bge-large-en-v1.5"

# --- Azure (uncomment if using Azure OpenAI) ---------------------------------
# CHAT_AZURE_API_BASE=
# CHAT_AZURE_API_VERSION=
# EMBEDDING_AZURE_API_BASE=
# EMBEDDING_AZURE_API_VERSION=

# --- Caches ------------------------------------------------------------------
USE_CHAT_CACHE=True
USE_EMBEDDING_CACHE=True
DS_DOCKER_ENABLE_CACHE=True


# -----------------------------------------------------------------------------
# 2. Filesystem layout (inputs, outputs, caches)
# -----------------------------------------------------------------------------

# Raw MBS CUSIP-level panel (parquet partitions keyed by fh_effdt)
MBS_DATA_DIR=./mbs_data

# Trained prepayment model checkpoints (.pt / .pkl) and scalers
MBS_MODEL_CHECKPOINT_DIR=./mbs_models
MBS_SCALER_PATH=./mbs_models/scaler.sav

# Reports, plots, scorecards, markdown narratives
MBS_OUTPUT_DIR=./mbs_output

# Persistent memory (Priority 7) — phase-aware trace + SOTA properties
MBS_MEMORY_PATH=./mbs_output/memory.json

# Persistent search-strategy state (Priority 6) — curriculum + cooldown history
MBS_SEARCH_STATE_PATH=./mbs_output/search_state.json

# Artifact cache root (Priority 9) — content-addressed by SHA-256 fingerprint
MBS_CACHE_DIR=./mbs_output/cache


# -----------------------------------------------------------------------------
# 3. Data contract (rdagent/scenarios/mbs_prepayment/scaffold.py)
# -----------------------------------------------------------------------------

# Target column and its valid range — predictions are clipped to [min, max]
MBS_TARGET_COLUMN=smm_decimal
MBS_TARGET_MIN=0.0
MBS_TARGET_MAX=1.0

# Panel key
MBS_CUSIP_COL=cusip
MBS_DATE_COL=fh_effdt

# MBS-theoretic required feature columns (comma-separated)
MBS_REQUIRED_COLUMNS=rate_incentive,coupon,wala

# Forbidden (future-leaking) columns — these must NEVER appear in features
MBS_FORBIDDEN_COLUMNS=future_smm,forward_smm,next_month_smm,forward_rate,future_rate_incentive

# Minimum look-ahead offset (in days) for macro features — guards against
# same-day leakage of unemployment/treasury curves
MBS_MACRO_LAG_DAYS_MIN=30


# -----------------------------------------------------------------------------
# 4. Temporal train/test split (MBSTrainTestSplit)
# -----------------------------------------------------------------------------

# Training cutoff (inclusive). Rows with fh_effdt > MBS_TRAIN_END_DATE are test.
MBS_TRAIN_END_DATE=2021-12-31

# Embargo gap between train-end and test-start (months) — set >0 to guard
# against autocorrelation leakage for high-persistence SMM_DECIMAL
MBS_EMBARGO_MONTHS=0


# -----------------------------------------------------------------------------
# 5. Evaluation harness (Priority 1 — evaluation.py)
# -----------------------------------------------------------------------------

# Coupon buckets for the per-bucket RMSE scorecard dimension. Semicolon-
# separated list of `lo:hi` half-open intervals [lo, hi); use 99 as upper
# sentinel for the "5.0+" bucket.
MBS_COUPON_BUCKETS=0.0:3.0;3.0:3.5;3.5:4.0;4.0:4.5;4.5:5.0;5.0:99.0

# Known macro regime transitions — the harness reports RMSE in the first 3
# months after each of these dates (ISO YYYY-MM-DD, comma-separated)
MBS_REGIME_TRANSITION_DATES=2013-05-01,2020-03-01,2022-03-01

# Column names used by the evaluation harness (keep aligned with scaffold)
MBS_COUPON_COL=coupon
MBS_RATE_INCENTIVE_COL=rate_incentive
MBS_WALA_COL=wala


# -----------------------------------------------------------------------------
# 6. Search strategy (Priority 6 — search_strategy.py)
# -----------------------------------------------------------------------------

# Relative RMSE improvement that counts as a "meaningful" iteration
MBS_IMPROVEMENT_THRESHOLD=0.05

# How many recent iterations are inspected for stall detection
MBS_STALL_WINDOW=3

# Iterations a failing component is put on cooldown before it can be retried
MBS_COOLDOWN_DURATION=2

# Consecutive failures that trigger a backtrack to SOTA
MBS_BACKTRACK_TRIGGER=3


# -----------------------------------------------------------------------------
# 7. Memory / context packing (Priority 7 — memory.py)
# -----------------------------------------------------------------------------

# Max recent failures surfaced to the next hypothesis prompt
MBS_MEMORY_MAX_FAILURES_SHOWN=3

# Max ModelProperties rows summarized in the context pack
MBS_MEMORY_MAX_PROPERTIES_SHOWN=5


# -----------------------------------------------------------------------------
# 8. Domain validator (Priority 8 — orchestration.py::DomainValidator)
# -----------------------------------------------------------------------------

# Minimum Spearman(pred, rate_incentive) — rejects rate-blind models
MBS_VALIDATOR_MIN_RATE_SENSITIVITY_CORR=0.3

# Hard cap on training wall-clock (seconds) before the validator auto-rejects
MBS_VALIDATOR_MAX_TRAINING_SECONDS=3600


# -----------------------------------------------------------------------------
# 9. Phase gates (Priority 8 — orchestration.py::PhaseGate)
# -----------------------------------------------------------------------------

# Baseline phase: overall RMSE must be below this to exit
MBS_GATE_BASELINE_MAX_RMSE=0.040

# Rate response phase: monotonicity + S-curve fit + inflection location
MBS_GATE_RATE_RESPONSE_MIN_MONOTONICITY=0.7
MBS_GATE_RATE_RESPONSE_MIN_S_CURVE_R2=0.6
MBS_GATE_RATE_RESPONSE_INFLECTION_MIN_BPS=50.0
MBS_GATE_RATE_RESPONSE_INFLECTION_MAX_BPS=150.0

# Dynamics phase: per-coupon worst-bucket RMSE ceiling
MBS_GATE_DYNAMICS_MAX_WORST_COUPON_RMSE=0.035

# Macro regime phase: regime-transition RMSE as a multiple of overall RMSE
MBS_GATE_MACRO_REGIME_TRANSITION_RATIO=2.0

# Per-phase iteration budgets (consumed before the orchestrator force-
# advances even without a gate pass)
MBS_PHASE_BUDGET_BASELINE=5
MBS_PHASE_BUDGET_RATE_RESPONSE=8
MBS_PHASE_BUDGET_DYNAMICS=8
MBS_PHASE_BUDGET_MACRO_REGIME=6
MBS_PHASE_BUDGET_ENSEMBLE=4


# -----------------------------------------------------------------------------
# 10. Execution environment (Priority 9 — execution_env.py)
# -----------------------------------------------------------------------------

# Per-stage compute budgets. Units: seconds for timeout, GiB for memory.
# Only TRAINING and ATTRIBUTION stages are allowed GPU access by default.

MBS_STAGE_DATA_LOAD_TIMEOUT_SECONDS=300
MBS_STAGE_DATA_LOAD_MEMORY_GB=16.0
MBS_STAGE_DATA_LOAD_CPU=4
MBS_STAGE_DATA_LOAD_ALLOW_GPU=False
MBS_STAGE_DATA_LOAD_MAX_RETRIES=1

MBS_STAGE_FEATURE_ENG_TIMEOUT_SECONDS=600
MBS_STAGE_FEATURE_ENG_MEMORY_GB=24.0
MBS_STAGE_FEATURE_ENG_CPU=8
MBS_STAGE_FEATURE_ENG_ALLOW_GPU=False
MBS_STAGE_FEATURE_ENG_MAX_RETRIES=0

MBS_STAGE_TRAINING_TIMEOUT_SECONDS=3600
MBS_STAGE_TRAINING_MEMORY_GB=32.0
MBS_STAGE_TRAINING_CPU=8
MBS_STAGE_TRAINING_ALLOW_GPU=True
MBS_STAGE_TRAINING_MAX_RETRIES=1

MBS_STAGE_EVALUATION_TIMEOUT_SECONDS=300
MBS_STAGE_EVALUATION_MEMORY_GB=8.0
MBS_STAGE_EVALUATION_CPU=4
MBS_STAGE_EVALUATION_ALLOW_GPU=False
MBS_STAGE_EVALUATION_MAX_RETRIES=0

MBS_STAGE_ATTRIBUTION_TIMEOUT_SECONDS=900
MBS_STAGE_ATTRIBUTION_MEMORY_GB=16.0
MBS_STAGE_ATTRIBUTION_CPU=4
MBS_STAGE_ATTRIBUTION_ALLOW_GPU=True
MBS_STAGE_ATTRIBUTION_MAX_RETRIES=0

# Mounted dataset layout (MountedDataset)
MBS_DATASET_PARTITIONS=fh_effdt
MBS_DATASET_FILE_FORMAT=parquet
MBS_DATASET_EXPECTED_COLUMNS=cusip,fh_effdt,smm_decimal,coupon,wala


# -----------------------------------------------------------------------------
# 11. Multi-agent personas (Priority 10 — personas.py)
# -----------------------------------------------------------------------------
# Model hints are preferences — callers may override them per call.
# Use a capable model for research-heavy personas and a cheap one for the
# high-volume debugger.

MBS_PERSONA_QUANT_RESEARCHER_MODEL=gpt-4-turbo
MBS_PERSONA_QUANT_RESEARCHER_TEMPERATURE=0.7

MBS_PERSONA_ML_ENGINEER_MODEL=gpt-4-turbo
MBS_PERSONA_ML_ENGINEER_TEMPERATURE=0.2

MBS_PERSONA_MODEL_VALIDATOR_MODEL=gpt-4-turbo
MBS_PERSONA_MODEL_VALIDATOR_TEMPERATURE=0.3

MBS_PERSONA_DATA_ENGINEER_MODEL=gpt-4o-mini
MBS_PERSONA_DATA_ENGINEER_TEMPERATURE=0.1

# Routing overrides (comma-separated `node=persona_kind` pairs). Leave empty
# to use DEFAULT_ROUTING in personas.py. Valid nodes: hypothesis_gen,
# hypothesis_select, hypothesis_critique, hypothesis_rewrite, component_gen,
# code_gen, code_fix, feedback_eval, domain_validation_explain, debug.
# Valid kinds: quant_researcher, ml_engineer, model_validator, data_engineer.
MBS_PERSONA_ROUTING_OVERRIDES=


# -----------------------------------------------------------------------------
# 12. Interpretability (Priority 4 — interpretability.py)
# -----------------------------------------------------------------------------

# Number of rows sampled before running IG / permutation importance
MBS_INTERPRETABILITY_N_SAMPLES=500

# Baseline strategy: "zero" (torch.zeros_like) or "mean" (per-feature mean)
MBS_INTERPRETABILITY_BASELINE_STRATEGY=zero

# Number of IG integration steps
MBS_IG_N_STEPS=50

# Model head to attribute: "cpr" (index 0) or "smm" (index 1)
MBS_IG_TARGET_OUTPUT=cpr

# Forward-pass batch size for IG — reduce on OOM
MBS_IG_BATCH_SIZE=32


# -----------------------------------------------------------------------------
# 13. Attribution workflow (LangGraph agent — app.py)
# -----------------------------------------------------------------------------
# Used by the question → plan → codegen → execute → review → report DAG.

# Subprocess wall-clock budget for LLM-generated attribution scripts
MBS_EXECUTION_TIMEOUT_SECONDS=300

# Max LLM-debug retries before escalating to the human reviewer
MBS_MAX_DEBUG_ATTEMPTS=3

# Hard cap on planner→reject→planner loops (prevents runaway sessions)
MBS_MAX_ITERATIONS=10

# Skip the human-in-the-loop interrupt (useful for CI / automated smoke tests)
MBS_SKIP_HUMAN_REVIEW=False


# -----------------------------------------------------------------------------
# 14. Reproducibility
# -----------------------------------------------------------------------------

# Global random seed propagated into IncrementalRunner.run_stage(random_seed=)
MBS_RANDOM_SEED=42

# Verbosity: DEBUG, INFO, WARNING, ERROR
MBS_LOG_LEVEL=INFO
